# Copy this file to apps/web/.env.local for local development.

# Public web URL for Auth0 callbacks and local redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3003

# Convex client URL. Filled in after the Convex project is created.
NEXT_PUBLIC_CONVEX_URL=

# Auth0 application settings for the web app.
AUTH0_SECRET=
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
